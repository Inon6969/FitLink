<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_admin_events_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitlinkBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_admin_events"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/fitlinkPrimary"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
            app:title="Manage Events"
            app:titleTextColor="@color/fitlinkBackground" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="5dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Event Management"
                android:textColor="@color/fitlinkPrimary"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/tv_admin_event_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/poppins_regular"
                android:text="Total events: 0"
                android:textColor="@color/fitlinkTextSecondary"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_admin_create_event"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/fitlinkPrimary"
                android:fontFamily="@font/poppins_bold"
                android:text="Create Event"
                android:textColor="@color/fitlinkBackground"
                android:textSize="18sp"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textEnd"
                app:iconSize="25dp"
                app:iconTint="@color/fitlinkBackground" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_admin_cleanup_events"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Clean Old Events"
                android:textColor="#FF4C4C"
                android:textSize="18sp"
                app:cornerRadius="24dp"
                app:icon="@drawable/ic_delete"
                app:iconGravity="textEnd"
                app:iconSize="25dp"
                app:iconTint="#FF4C4C"
                app:strokeColor="#FF4C4C"
                app:strokeWidth="1.5dp"
                android:textAllCaps="false" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="Filter Events"
                        android:textColor="@color/fitlinkPrimary"
                        android:textSize="20sp" />

                    <Spinner
                        android:id="@+id/spinner_admin_events_search_type"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginBottom="12dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/layout_admin_search_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Type to search..."
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:startIconDrawable="@android:drawable/ic_menu_search">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edit_admin_events_search"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:textSize="16sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <Spinner
                            android:id="@+id/spinner_admin_events_search_options"
                            android:layout_width="match_parent"
                            android:layout_height="55dp"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/layout_admin_range_picker"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_admin_range_start"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="55dp"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/poppins_medium"
                                android:text="Start"
                                android:textAllCaps="false"
                                android:textColor="@color/fitlinkPrimary"
                                app:cornerRadius="12dp"
                                app:strokeColor="@color/fitlinkPrimary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_admin_range_end"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="55dp"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:fontFamily="@font/poppins_medium"
                                android:text="End"
                                android:textAllCaps="false"
                                android:textColor="@color/fitlinkPrimary"
                                app:cornerRadius="12dp"
                                app:strokeColor="@color/fitlinkPrimary" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layout_admin_duration_picker"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:baselineAligned="false"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                android:hint="Min Mins"
                                app:boxBackgroundMode="outline"
                                app:boxCornerRadiusBottomEnd="16dp"
                                app:boxCornerRadiusBottomStart="16dp"
                                app:boxCornerRadiusTopEnd="16dp"
                                app:boxCornerRadiusTopStart="16dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_admin_duration_min"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_regular"
                                    android:inputType="number"
                                    android:textSize="16sp" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:hint="Max Mins"
                                app:boxBackgroundMode="outline"
                                app:boxCornerRadiusBottomEnd="16dp"
                                app:boxCornerRadiusBottomStart="16dp"
                                app:boxCornerRadiusTopEnd="16dp"
                                app:boxCornerRadiusTopStart="16dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_admin_duration_max"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_regular"
                                    android:inputType="number"
                                    android:textSize="16sp" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </FrameLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="30dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="5dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_admin_events_list"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false" />

                    <LinearLayout
                        android:id="@+id/admin_events_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="40dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:layout_marginBottom="16dp"
                            android:alpha="0.3"
                            android:src="@drawable/ic_sport" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:text="No Events Found"
                            android:textColor="@color/fitlinkTextSecondary"
                            android:textSize="18sp" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/admin_events_progress_bar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>