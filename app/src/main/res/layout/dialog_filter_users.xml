<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="ltr"
    android:fillViewport="true">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/fitlinkBackground"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="#1F000000"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Advanced Filters"
                android:textColor="@color/fitlinkPrimary"
                android:textSize="22sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#0D9169F9"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#269169F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_medium"
                        android:text="User Role"
                        android:textColor="@color/fitlinkTextSecondary"
                        android:textSize="13sp" />

                    <Spinner
                        android:id="@+id/spinner_filter_role"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:background="@android:color/transparent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#0D9169F9"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#269169F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="Email Address"
                        android:textColor="@color/fitlinkTextSecondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/edit_filter_email"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/dialog_background"
                        android:backgroundTint="@color/fitlinkBackground"
                        android:hint="e.g. user@email.com"
                        android:inputType="textEmailAddress"
                        android:paddingStart="12dp"
                        android:textSize="14sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="Phone Number"
                        android:textColor="@color/fitlinkTextSecondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/edit_filter_phone"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:background="@drawable/dialog_background"
                        android:backgroundTint="@color/fitlinkBackground"
                        android:hint="e.g. 0501234567"
                        android:inputType="phone"
                        android:paddingStart="12dp"
                        android:textSize="14sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset_filters"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_marginEnd="8dp"
                    android:text="Clear All"
                    android:textColor="@color/fitlinkPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_apply_filters"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:backgroundTint="@color/fitlinkPrimary"
                    android:text="Apply Filters"
                    android:textColor="@color/fitlinkBackground"
                    android:textSize="14sp"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</ScrollView>