<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:text="Create New Event"
            android:textColor="@color/fitlinkPrimary"
            android:textSize="30sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_event_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:hint="Event Title (e.g. Yoga in the Park)"
                android:inputType="textCapWords" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxBackgroundMode="outline">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_event_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:hint="Description (Optional)"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Sport Type"
            android:textColor="@color/fitlinkPrimary" />

        <Spinner
            android:id="@+id/spinner_event_sport"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Difficulty Level"
            android:textColor="@color/fitlinkPrimary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupEventLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:chipSpacingHorizontal="12dp"
            app:chipSpacingVertical="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEventBeginner"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:fontFamily="@font/poppins_medium"
                android:text="Beginner"
                android:textColor="@color/chip_text_state_list"
                app:chipBackgroundColor="@color/chip_background_state_list"
                app:chipCornerRadius="12dp"
                app:chipStrokeColor="@color/fitlinkPrimary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEventIntermediate"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="Intermediate"
                android:textColor="@color/chip_text_state_list"
                app:chipBackgroundColor="@color/chip_background_state_list"
                app:chipCornerRadius="12dp"
                app:chipStrokeColor="@color/fitlinkPrimary"
                app:chipStrokeWidth="1dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEventAdvanced"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:text="Advanced"
                android:textColor="@color/chip_text_state_list"
                app:chipBackgroundColor="@color/chip_background_state_list"
                app:chipCornerRadius="12dp"
                app:chipStrokeColor="@color/fitlinkPrimary"
                app:chipStrokeWidth="1dp" />
        </com.google.android.material.chip.ChipGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_event_date"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_medium"
                android:text="Select Date"
                android:textAllCaps="false"
                android:textColor="@color/fitlinkPrimary"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_today"
                app:strokeColor="@color/fitlinkPrimary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_event_time"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_medium"
                android:text="Select Time"
                android:textAllCaps="false"
                android:textColor="@color/fitlinkPrimary"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:strokeColor="@color/fitlinkPrimary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_event_duration"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_medium"
                android:text="Duration"
                android:textAllCaps="false"
                android:textColor="@color/fitlinkPrimary"
                app:cornerRadius="12dp"
                app:strokeColor="@color/fitlinkPrimary" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                app:boxBackgroundMode="outline">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_event_max_participants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:hint="Participants (0=Any)"
                    android:inputType="number"
                    android:text="0" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="@font/poppins_regular"
            android:text="Location:"
            android:textColor="@color/fitlinkTextSecondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_event_location"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:fontFamily="@font/poppins_medium"
            android:text="Select Location on Map"
            android:textAllCaps="false"
            android:textColor="@color/fitlinkPrimary"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_dialog_map"
            app:iconGravity="textStart"
            app:iconTint="@color/fitlinkPrimary"
            app:strokeColor="@color/fitlinkPrimary" />

        <TextView
            android:id="@+id/tv_event_selected_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:text="No location selected"
            android:textColor="@color/fitlinkTextSecondary"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/progressBar_create_event"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_event_save"
                android:layout_width="145dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:backgroundTint="@color/fitlinkPrimary"
                android:fontFamily="@font/poppins_medium"
                android:text="Create"
                android:textSize="18sp"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_event_cancel"
                android:layout_width="145dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:backgroundTint="@color/white"
                android:fontFamily="@font/poppins_medium"
                android:text="Cancel"
                android:textColor="@color/fitlinkPrimary"
                android:textSize="18sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/fitlinkPrimary"
                app:strokeWidth="2dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>